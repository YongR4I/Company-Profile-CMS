{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "siteName": {
      "type": "string"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "navLinks": {
      "type": "component",
      "repeatable": true,
      "component": "links.nav-link"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "links.social-link"
    },
    "footerCompanyLinks": {
      "type": "component",
      "repeatable": true,
      "component": "links.nav-link"
    },
    "footerServiceLinks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service.service"
    },
    "officeAddress": {
      "type": "text"
    },
    "workshopAddress": {
      "type": "text"
    },
    "heroFooterText": {
      "type": "text"
    }
  }
}