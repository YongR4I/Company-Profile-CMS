# Server
HOST=0.0.0.0
PORT=1337

# Secrets — Generate for production via: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# APP_KEYS requires 4 comma-separated values
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your-salt-here
ADMIN_JWT_SECRET=your-secret-here
JWT_SECRET=your-secret-here
TRANSFER_TOKEN_SALT=your-salt-here
ENCRYPTION_KEY=your-key-here

# Database
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=Compro-PKL
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-strong-password
DATABASE_SSL=false

# Optional: Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000
